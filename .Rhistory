all_data %>%
mutate(change = map(data, ~
.x %>%
group_by(FaceID) %>%
summarize(
mean_change = mean(SecondRating - FirstRating),
.groups = "drop"
)
)) %>%
select(agent_type, change) %>%
unnest(change) %>%
group_by(agent_type) %>%
group_split() %>%
purrr::walk(function(df) {
overall_mean <- mean(df$mean_change)
p <- df %>%
ggplot(aes(
x = reorder(FaceID, mean_change),
y = mean_change,
group = 1
)) +
geom_line() +
geom_point(aes(
color = ifelse(mean_change > 0,
"Increased Trust",
"Decreased Trust")
), size = 2.5) +
geom_hline(
yintercept = overall_mean,
linetype = "dashed",
linewidth = 0.7
) +
scale_color_manual(values = c(
"Increased Trust" = "#2E8B57",
"Decreased Trust" = "#CD5C5C"
)) +
labs(
title = paste("Mean Change in Trust Ratings:", unique(df$agent_type)),
x = "Face ID",
y = "Mean Change",
color = "Trust Change"
) +
theme_minimal() +
theme(
axis.text.x = element_blank(),
axis.ticks.x = element_blank()
)
print(p)
})
